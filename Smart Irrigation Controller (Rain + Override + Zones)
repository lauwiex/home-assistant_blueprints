blueprint:
  name: Smart Irrigation Controller (Clean + Actionable)
  domain: automation

  input:
    notify_device:
      name: Notificatie device
      selector:
        device: {}

    sprinkler_left:
      selector:
        entity:
          domain: switch

    sprinkler_right:
      selector:
        entity:
          domain: switch

trigger:
  - platform: time
    at: "21:00:00"

action:

  - choose:

      # ---------------- SEIZOEN ----------------
      - conditions:
          - condition: template
            value_template: "{{ now().month < 5 or now().month > 10 }}"
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: Buiten seizoen (mei–okt)
              data:
                actions:
                  - action: START_SPRINKLER
                    title: Toch sproeien

      # ---------------- REGEN 1D ----------------
      - conditions:
          - condition: numeric_state
            entity_id: sensor.bergschenhoek_rain_1d
            above: 1.5
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Te nat: {{ states('sensor.bergschenhoek_rain_1d') }} mm
              data:
                actions:
                  - action: START_SPRINKLER
                    title: Toch sproeien

      # ---------------- REGEN VANDAAG ----------------
      - conditions:
          - condition: numeric_state
            entity_id: sensor.bergschenhoek_maximum_rain_1d
            above: 0.4
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Regen verwacht vandaag:
                {{ states('sensor.bergschenhoek_maximum_rain_1d') }} mm
              data:
                actions:
                  - action: START_SPRINKLER
                    title: Toch sproeien

      # ---------------- REGEN 2D ----------------
      - conditions:
          - condition: numeric_state
            entity_id: sensor.buienradar_maximum_rain_2d
            above: 0.8
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Regen komende 2 dagen:
                {{ states('sensor.buienradar_maximum_rain_2d') }} mm
              data:
                actions:
                  - action: START_SPRINKLER
                    title: Toch sproeien

    default:

      # LINKS
      - service: switch.turn_on
        target:
          entity_id: !input sprinkler_left

      - delay: "00:15:00"

      - service: switch.turn_off
        target:
          entity_id: !input sprinkler_left

      - delay: "00:01:00"

      # RECHTS
      - service: switch.turn_on
        target:
          entity_id: !input sprinkler_right

      - delay: "00:15:00"

      - service: switch.turn_off
        target:
          entity_id: !input sprinkler_right
