blueprint:
  name: Smart Irrigation Controller (Rain + Override + Zones)
  description: Automatische irrigatie met regenlogica + handmatige override met slimme duur.
  domain: automation

  input:
    notify_device:
      name: Notificatie device
      selector:
        device: {}

    sprinkler_left:
      name: Sprinkler links
      selector:
        entity:
          domain: switch

    sprinkler_right:
      name: Sprinkler rechts
      selector:
        entity:
          domain: switch

    rain_1d:
      name: Regen 1 dag
      selector:
        entity:
          domain: sensor

    rain_max_1d:
      name: Max regen 1 dag
      selector:
        entity:
          domain: sensor

    rain_max_2d:
      name: Max regen 2 dagen
      selector:
        entity:
          domain: sensor

    override_action:
      name: Override actie (notification action)
      default: START_SPRINKLER

trigger:
  - platform: time
    at: "21:00:00"

variables:
  rain1d: "{{ states(blueprint.inputs.rain_1d) | float(0) }}"
  rain1d_max: "{{ states(blueprint.inputs.rain_max_1d) | float(0) }}"
  rain2d_max: "{{ states(blueprint.inputs.rain_max_2d) | float(0) }}"

action:
  - choose:

      # ---------------- SEIZOEN ----------------
      - conditions:
          - condition: template
            value_template: >
              {{ now().month < 5 or now().month > 10 }}
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: Buiten seizoen (mei–okt)
              data:
                actions:
                  - action: !input override_action
                    title: Toch sproeien

      # ---------------- REGEN 1D ----------------
      - conditions:
          - condition: template
            value_template: "{{ rain1d > 1.5 }}"
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Te nat: {{ rain1d }} mm afgelopen dag
              data:
                actions:
                  - action: !input override_action
                    title: Toch sproeien

      # ---------------- REGEN VANDAAG ----------------
      - conditions:
          - condition: template
            value_template: "{{ rain1d_max > 0.4 }}"
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Regen verwacht vandaag: {{ rain1d_max }} mm
              data:
                actions:
                  - action: !input override_action
                    title: Toch sproeien

      # ---------------- REGEN 2D ----------------
      - conditions:
          - condition: template
            value_template: "{{ rain2d_max > 0.8 }}"
        sequence:
          - action: notify.send_message
            target:
              device_id: !input notify_device
            data:
              title: Sprinkler overgeslagen
              message: >
                Regen komende 2 dagen: {{ rain2d_max }} mm
              data:
                actions:
                  - action: !input override_action
                    title: Toch sproeien

    default:

      # LINKS
      - service: switch.turn_on
        target:
          entity_id: !input sprinkler_left

      - delay: "00:15:00"

      - service: switch.turn_off
        target:
          entity_id: !input sprinkler_left

      - delay: "00:01:00"

      # RECHTS
      - service: switch.turn_on
        target:
          entity_id: !input sprinkler_right

      - delay: "00:15:00"

      - service: switch.turn_off
        target:
          entity_id: !input sprinkler_right
