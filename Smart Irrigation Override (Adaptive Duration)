blueprint:
  name: 
  description: Handmatige override via notificatie met slimme sproeitijd op basis van regenrisico.
  domain: automation

  input:
    notify_device:
      name: Notificatie device
      selector:
        device: {}

    sprinkler_left:
      name: Sprinkler links
      selector:
        entity:
          domain: switch

    sprinkler_right:
      name: Sprinkler rechts
      selector:
        entity:
          domain: switch

    rain_1d:
      name: Regen 1 dag (max)
      selector:
        entity:
          domain: sensor

    rain_2d:
      name: Regen 2 dagen (max)
      selector:
        entity:
          domain: sensor

    override_action:
      name: Notification action
      default: START_SPRINKLER

trigger:
  - platform: event
    event_type: mobile_app_notification_action
    event_data:
      action: !input override_action

variables:
  rain1d: "{{ states(blueprint.inputs.rain_1d) | float(0) }}"
  rain2d: "{{ states(blueprint.inputs.rain_2d) | float(0) }}"

  duration: >
    {% if rain2d > 1 or rain1d > 0.8 %}
      00:05:00
    {% elif rain2d > 0.5 or rain1d > 0.4 %}
      00:10:00
    {% else %}
      00:15:00
    {% endif %}

action:

  - action: notify.send_message
    target:
      device_id: !input notify_device
    data:
      title: Sprinkler override gestart
      message: >
        Handmatig gestart.
        Regenrisico:
        vandaag {{ rain1d }} mm / 2 dagen {{ rain2d }} mm
        Tijd per zone: {{ duration }}

  # -------------------------
  # LINKS
  # -------------------------
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_left

  - delay: "{{ duration }}"

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_left

  - delay: "00:01:00"

  # -------------------------
  # RECHTS
  # -------------------------
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_right

  - delay: "{{ duration }}"

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_right

  - action: notify.send_message
    target:
      device_id: !input notify_device
    data:
      title: Sprinkler override
      message: Override afgerond
