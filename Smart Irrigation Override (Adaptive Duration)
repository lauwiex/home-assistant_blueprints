blueprint:
  name: Smart Irrigation Override (Stable Adaptive)
  domain: automation

  input:
    notify_device:
      name: Notificatie device
      selector:
        device: {}

    sprinkler_left:
      name: Sprinkler links
      selector:
        entity:
          domain: switch

    sprinkler_right:
      name: Sprinkler rechts
      selector:
        entity:
          domain: switch

trigger:
  - platform: event
    event_type: mobile_app_notification_action
    event_data:
      action: START_SPRINKLER

action:

  - variables:
      rain1d: "{{ states('sensor.bergschenhoek_maximum_rain_1d') | float(0) }}"
      rain2d: "{{ states('sensor.buienradar_maximum_rain_2d') | float(0) }}"

  - choose:

      # 🌧️ NAT → kort
      - conditions:
          - condition: template
            value_template: "{{ rain1d > 0.8 or rain2d > 1 }}"
        sequence:
          - variables:
              duration: "00:05:00"

      # 🌥️ HALF → medium
      - conditions:
          - condition: template
            value_template: "{{ rain1d > 0.4 or rain2d > 0.5 }}"
        sequence:
          - variables:
              duration: "00:10:00"

    default:
      - variables:
          duration: "00:15:00"

  - action: notify.send_message
    target:
      device_id: !input notify_device
    data:
      title: Sprinkler override
      message: >
        Regen 1d: {{ rain1d }} mm / 2d: {{ rain2d }} mm
        Duur per zone: {{ duration }}

  # LINKS
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_left

  - delay: "{{ duration }}"

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_left

  - delay: "00:01:00"

  # RECHTS
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_right

  - delay: "{{ duration }}"

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_right
