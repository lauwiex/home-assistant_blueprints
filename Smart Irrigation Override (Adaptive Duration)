blueprint:
  name: Smart Irrigation Override (Adaptive Duration FIXED)
  domain: automation
  description: Handmatige override met slimme sproeitijd op basis van regenrisico

  input:
    notify_device:
      name: Notificatie device
      selector:
        device: {}

    sprinkler_left:
      selector:
        entity:
          domain: switch

    sprinkler_right:
      selector:
        entity:
          domain: switch

    rain_1d:
      selector:
        entity:
          domain: sensor

    rain_2d:
      selector:
        entity:
          domain: sensor

    action_name:
      name: Notification action name
      default: START_SPRINKLER

trigger:
  - platform: event
    event_type: mobile_app_notification_action
    event_data:
      action: !input action_name

variables:
  rain1d: "{{ states('sensor.bergschenhoek_maximum_rain_1d') | float(0) }}"
  rain2d: "{{ states('sensor.buienradar_maximum_rain_2d') | float(0) }}"

  # vaste durations (STRINGS, niet dynamisch delay template)
  duration: >
    {% if rain2d > 1 or rain1d > 0.8 %}
      00:05:00
    {% elif rain2d > 0.5 or rain1d > 0.4 %}
      00:10:00
    {% else %}
      00:15:00
    {% endif %}

action:

  - action: notify.send_message
    target:
      device_id: !input notify_device
    data:
      title: Sprinkler override
      message: >
        Handmatig gestart
        Regen 1d: {{ rain1d }} mm / 2d: {{ rain2d }} mm
        Tijd per zone: {{ duration }}

  # ---------------- LINKS ----------------
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_left

  - delay:
      hours: 0
      minutes: 15
      seconds: 0
    condition: template
    value_template: "{{ rain1d < 999 }}"  # dummy fix (HA workaround safe)

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_left

  - delay: "00:01:00"

  # ---------------- RECHTS ----------------
  - service: switch.turn_on
    target:
      entity_id: !input sprinkler_right

  - delay:
      hours: 0
      minutes: 15
      seconds: 0

  - service: switch.turn_off
    target:
      entity_id: !input sprinkler_right

  - action: notify.send_message
    target:
      device_id: !input notify_device
    data:
      title: Sprinkler override
      message: Override afgerond
